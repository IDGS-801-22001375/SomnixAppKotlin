<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="34dp">

        <TextView
            android:id="@+id/txtLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicia Sesión"
            android:textColor="#0B2D5B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Por favor, inicia sesión para continuar&#10;usando la app..."
            android:textColor="#102A43"
            android:textSize="20sp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtLogin"
            app:layout_constraintStart_toStartOf="@id/txtLogin"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtOpciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresar por las siguientes opciones:"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtDescripcion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutRedes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtOpciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/cromo"
                android:layout_marginEnd="25dp" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/x"
                android:layout_marginEnd="25dp" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/facebook" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtCorreo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O ingresa con tu correo electrónico"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRedes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/edtEmailLogin"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:hint="Ingresa tu email"
            android:textSize="16sp"
            android:textColor="#102A43"
            android:textColorHint="#A8A8A8"
            android:background="@drawable/bg_input"
            android:paddingStart="70dp"
            android:paddingEnd="20dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtCorreo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iconEmailLogin"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/correo"
            app:layout_constraintStart_toStartOf="@id/edtEmailLogin"
            app:layout_constraintTop_toTopOf="@id/edtEmailLogin"
            app:layout_constraintBottom_toBottomOf="@id/edtEmailLogin"
            android:layout_marginStart="20dp" />

        <EditText
            android:id="@+id/edtPasswordLogin"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:hint="Ingresa tu contraseña"
            android:textSize="16sp"
            android:textColor="#102A43"
            android:textColorHint="#A8A8A8"
            android:background="@drawable/bg_input"
            android:paddingStart="70dp"
            android:paddingEnd="60dp"
            android:inputType="textPassword"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/edtEmailLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iconLockLogin"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/pass"
            app:layout_constraintStart_toStartOf="@id/edtPasswordLogin"
            app:layout_constraintTop_toTopOf="@id/edtPasswordLogin"
            app:layout_constraintBottom_toBottomOf="@id/edtPasswordLogin"
            android:layout_marginStart="20dp" />

        <ImageView
            android:id="@+id/iconEyeLogin"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/invisible"
            app:layout_constraintEnd_toEndOf="@id/edtPasswordLogin"
            app:layout_constraintTop_toTopOf="@id/edtPasswordLogin"
            app:layout_constraintBottom_toBottomOf="@id/edtPasswordLogin"
            android:layout_marginEnd="18dp" />

        <TextView
            android:id="@+id/txtOlvidaste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="#102A43"
            android:textSize="14sp"
            android:layout_marginTop="35dp"
            app:layout_constraintTop_toBottomOf="@id/edtPasswordLogin"
            app:layout_constraintEnd_toEndOf="@id/edtPasswordLogin" />

        <Button
            android:id="@+id/btnIniciarSesion"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:text="Iniciar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:backgroundTint="#071F3D"
            android:layout_marginTop="25dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            app:layout_constraintTop_toBottomOf="@id/txtOlvidaste"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnIniciarSesion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes una cuenta? "
                android:textColor="#102A43"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtIrRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrate"
                android:textColor="#0B5CAD"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true"
    tools:context=".AgregarRutaActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:padding="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_button"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#071F3D"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Nueva ruta"
            android:textColor="#071F3D"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/btnBack"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Registra un recorrido para iniciar monitoreo cuando lo necesites."
            android:textColor="#667085"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/txtTitulo"
            app:layout_constraintStart_toStartOf="@id/txtTitulo"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/cardFormulario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/edtNombreRuta"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Nombre de la ruta"
                android:inputType="textCapWords"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:textColor="#071F3D"
                android:textColorHint="#98A2B3" />

            <EditText
                android:id="@+id/edtOrigen"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:hint="Origen"
                android:inputType="textCapWords"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:textColor="#071F3D"
                android:textColorHint="#98A2B3" />

            <EditText
                android:id="@+id/edtDestino"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:hint="Destino"
                android:inputType="textCapWords"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:textColor="#071F3D"
                android:textColorHint="#98A2B3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtDistancia"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:hint="Km"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textColor="#071F3D"
                    android:textColorHint="#98A2B3" />

                <EditText
                    android:id="@+id/edtDuracion"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:hint="Minutos"
                    android:inputType="number"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textColor="#071F3D"
                    android:textColorHint="#98A2B3" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnGuardarRuta"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="26dp"
            android:backgroundTint="#071F3D"
            android:text="Guardar ruta"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFormulario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
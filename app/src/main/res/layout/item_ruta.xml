<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_icon_button"
            android:padding="10dp"
            android:src="@drawable/ic_route"
            app:tint="#071F3D" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNombreRuta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ruta Universidad"
                android:textColor="#071F3D"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOrigenDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Casa → Universidad"
                android:textColor="#667085"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtEstadoRuta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Disponible"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="#E6EAF0" />

    <TextView
        android:id="@+id/txtDetalleRuta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="14.2 km • 28 min"
        android:textColor="#071F3D"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Selecciona esta ruta para iniciar el monitoreo del conductor."
        android:textColor="#667085"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnIniciarRuta"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:backgroundTint="#071F3D"
        android:text="Seleccionar ruta"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
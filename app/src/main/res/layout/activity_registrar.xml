<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="34dp">

        <TextView
            android:id="@+id/txtRegistrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Regístrate"
            android:textColor="#0B2D5B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Por favor, regístrate con tu email u&#10;otras opciones para continuar..."
            android:textColor="#102A43"
            android:textSize="20sp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtRegistrate"
            app:layout_constraintStart_toStartOf="@id/txtRegistrate"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtOpciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresar por las siguientes opciones:"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtDescripcion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutRedes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtOpciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/cromo"
                android:textColor="#0B2D5B"
                android:textSize="34sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="25dp" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/x"
                android:textColor="#0B2D5B"
                android:textSize="34sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="25dp" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/facebook"
                android:textColor="#0B2D5B"
                android:textSize="38sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtCorreo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O ingresa con tu correo electrónico"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRedes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:hint="Ingresa tu email"
            android:textSize="16sp"
            android:textColor="#102A43"
            android:textColorHint="#A8A8A8"
            android:background="@drawable/bg_input"
            android:paddingStart="70dp"
            android:paddingEnd="20dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/txtCorreo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iconEmail"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/correo"
            android:textColor="#0B5CAD"
            android:textSize="25sp"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="@id/edtEmail"
            app:layout_constraintTop_toTopOf="@id/edtEmail"
            app:layout_constraintBottom_toBottomOf="@id/edtEmail"
            android:layout_marginStart="20dp" />

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:hint="Ingresa tu contraseña"
            android:textSize="16sp"
            android:textColor="#102A43"
            android:textColorHint="#A8A8A8"
            android:background="@drawable/bg_input"
            android:paddingStart="70dp"
            android:paddingEnd="60dp"
            android:inputType="textPassword"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/edtEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iconLock"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/pass"
            android:textColor="#0B5CAD"
            android:textSize="24sp"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="@id/edtPassword"
            app:layout_constraintTop_toTopOf="@id/edtPassword"
            app:layout_constraintBottom_toBottomOf="@id/edtPassword"
            android:layout_marginStart="20dp" />

        <ImageView
            android:id="@+id/iconEye"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@mipmap/invisible"
            android:textColor="#000000"
            android:textSize="26sp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="@id/edtPassword"
            app:layout_constraintTop_toTopOf="@id/edtPassword"
            app:layout_constraintBottom_toBottomOf="@id/edtPassword"
            android:layout_marginEnd="18dp" />

        <Button
            android:id="@+id/btnRegistrarme"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:text="Registrarme"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:backgroundTint="#071F3D"
            android:layout_marginTop="20dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            app:layout_constraintTop_toBottomOf="@id/edtPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnRegistrarme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes una cuenta? "
                android:textColor="#102A43"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtIniciarSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicia sesión"
                android:textColor="#0B5CAD"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPrivacidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="25dp"
            app:layout_constraintTop_toBottomOf="@id/layoutLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <CheckBox
                android:id="@+id/checkPrivacidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#0B5CAD"
                android:checked="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acepto las políticas de privacidad"
                android:textColor="#102A43"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
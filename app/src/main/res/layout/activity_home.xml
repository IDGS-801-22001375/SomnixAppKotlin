<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="#F4F6F8"
    android:fillViewport="true"
    tools:context=".HomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="4dp"
        android:padding="24dp">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_button"
            android:padding="9dp"
            android:src="@drawable/ic_menu"
            app:tint="#071F3D"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Somnix"
            android:textColor="#071F3D"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/btnMenu"
            app:layout_constraintTop_toBottomOf="@id/btnMenu"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard de monitoreo"
            android:textColor="#667085"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/txtTitulo"
            app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_dark"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:text="Activo"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txtTitulo" />

        <LinearLayout
            android:id="@+id/cardPrincipal"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="22dp"
            app:layout_constraintTop_toBottomOf="@id/txtSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ruta actual"
                android:textColor="#B8C7D9"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtRutaActual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin ruta activa"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtFatiga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatiga detectada: 0%"
                android:textColor="#DDE7F3"
                android:textSize="14sp"
                android:layout_marginTop="18dp" />

            <ProgressBar
                android:id="@+id/progressFatiga"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0" />

        </LinearLayout>

        <Button
            android:id="@+id/btnEmpezarRuta"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:backgroundTint="#071F3D"
            android:text="Empezar ruta"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardPrincipal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtAccesos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accesos rápidos"
            android:textColor="#071F3D"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/btnEmpezarRuta"
            app:layout_constraintStart_toStartOf="parent" />

        <GridLayout
            android:id="@+id/gridOpciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/txtAccesos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/cardMisRutas"
                android:layout_width="0dp"
                android:layout_height="125dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_route"
                    app:tint="#071F3D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis rutas"
                    android:textColor="#071F3D"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardEstadisticas"
                android:layout_width="0dp"
                android:layout_height="125dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_statistics"
                    app:tint="#071F3D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Estadísticas"
                    android:textColor="#071F3D"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCamara"
                android:layout_width="0dp"
                android:layout_height="125dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_camera"
                    app:tint="#071F3D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoreo"
                    android:textColor="#071F3D"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardAlertas"
                android:layout_width="0dp"
                android:layout_height="125dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_alert"
                    app:tint="#071F3D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alertas"
                    android:textColor="#071F3D"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

        </GridLayout>

        <LinearLayout
            android:id="@+id/cardUltimaAlerta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@id/gridOpciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Última alerta"
                android:textColor="#071F3D"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtUltimaAlerta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No hay alertas recientes"
                android:textColor="#667085"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="15dp"
    android:background="#F4F6F8"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_icon_button"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="#071F3D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTituloAlertas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="Alertas"
        android:textColor="#071F3D"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/btnBack"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <TextView
        android:id="@+id/txtSubtituloAlertas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Historial de alertas registradas durante el viaje."
        android:textColor="#667085"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloAlertas"
        app:layout_constraintStart_toStartOf="@id/txtTituloAlertas"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtSinAlertas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No hay alertas recientes"
        android:textColor="#667085"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/txtSubtituloAlertas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlertas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtituloAlertas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>